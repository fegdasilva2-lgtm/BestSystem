# Variaveis publicas (NEXT_PUBLIC_*) sao expostas ao browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Variaveis de servidor (nao usar NEXT_PUBLIC_). Em producao, definir na Vercel.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Token de seguranca para a tela de setup (/setup).
# Se definido, a rota /setup so funciona com ?secret=SETUP_SECRET na URL.
# Gere um token forte: openssl rand -hex 32
SETUP_SECRET=
